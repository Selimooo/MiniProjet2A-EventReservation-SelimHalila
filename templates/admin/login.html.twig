<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login — EventApp</title>
    <link rel="stylesheet" href="/css/app.css">
</head>
<body>
<div class="container-sm" style="margin-top:5rem;">
    <div class="card">
        <h1 style="font-size:1.5rem;margin-bottom:.25rem;">🛡 Admin Login</h1>
        <p style="color:var(--muted);margin-bottom:1.5rem;">EventApp Administration Panel</p>

        {% if error %}
        <div class="alert alert-danger">{{ error.messageKey | trans(error.messageData, 'security') }}</div>
        {% endif %}

        <form method="post" action="{{ path('admin_login_check') }}">
            <div class="form-group">
                <label for="username">Username</label>
                <input type="text" id="username" name="_username"
                       value="{{ last_username }}" required autofocus
                       placeholder="admin">
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="_password"
                       required placeholder="••••••••">
            </div>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            <button type="submit" class="btn btn-primary btn-block">Login</button>
        </form>

        <p style="margin-top:1rem;font-size:.8rem;color:var(--muted);text-align:center;">
            <a href="/">← Back to site</a>
        </p>
    </div>
</div>
</body>
</html>
