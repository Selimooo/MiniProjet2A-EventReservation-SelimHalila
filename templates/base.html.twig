<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Event Reservation{% endblock %} — EventApp</title>
    <link rel="stylesheet" href="/css/app.css">
    {% block stylesheets %}{% endblock %}
</head>
<body data-page="{% block page_id %}{% endblock %}">

<nav class="navbar">
    <div class="navbar-inner">
        <a href="/" class="navbar-brand">🎟 EventApp</a>
        <div id="nav-auth"></div>
    </div>
</nav>

{% block body %}{% endblock %}

<footer style="text-align:center;padding:2rem;color:var(--muted);font-size:.85rem;border-top:1px solid var(--border);margin-top:4rem;">
    © 2026 EventApp — ISSAT Sousse
</footer>

<script src="/js/auth.js"></script>
<script src="/js/app.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>
