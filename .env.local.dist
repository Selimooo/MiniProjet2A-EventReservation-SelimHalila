# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to git

APP_ENV=dev
APP_SECRET=generate_a_strong_random_secret_here

# Database - change credentials as needed
DATABASE_URL="postgresql://app_user:your_password@127.0.0.1:5432/event_reservation?serverVersion=15&charset=utf8"

# JWT
JWT_PASSPHRASE=your_strong_passphrase_here

# WebAuthn - must match your actual domain
APP_DOMAIN=localhost
WEBAUTHN_RP_NAME="Event Reservation App"
