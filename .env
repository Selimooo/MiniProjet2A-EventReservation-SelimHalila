APP_ENV=dev
APP_SECRET=change_me_to_a_random_secret_32chars

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://app:!ChangeMe!@127.0.0.1:5432/event_reservation?serverVersion=15&charset=utf8"
###< doctrine/doctrine-bundle ###

###> JWT Configuration ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me_in_production
JWT_TOKEN_TTL=3600
###< JWT Configuration ###

###> WebAuthn Configuration ###
APP_DOMAIN=localhost
WEBAUTHN_RP_NAME="Event Reservation App"
###< WebAuthn Configuration ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###
